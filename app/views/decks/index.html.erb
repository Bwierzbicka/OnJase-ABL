<h1 class="text-center">Flashcard Decks</h1>

<div class="ms-3">
  <ul class="list-unstyled">
    <% @decks.each do |deck| %>
      <li>
        <%= link_to deck.name, play_deck_deck_path(deck) %>
      </li>
    <% end %>
  </ul>

  <%= link_to "New Deck", new_deck_path, class: "btn btn-primary" %>
</div>
