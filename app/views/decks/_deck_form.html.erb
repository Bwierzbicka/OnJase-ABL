<div data-controller="deck-search">
  <button class="deck-overlay__trigger" data-action="click->deck-search#open">
    <i class="fa-solid fa-plus"></i>
  </button>

  <div data-deck-search-target="overlay" class="deck-overlay deck-overlay--hidden">
    <div class="deck-overlay__backdrop" data-action="click->deck-search#close"></div>
    <div class="deck-overlay__panel">
      <button class="deck-overlay__close" data-action="click->deck-search#close">&times;</button>
      <p class="mb-1 fw-bold">Create a new deck</p>

      <%= form_with url: create_deck_decks_path, method: :post,
                    data: { action: "submit->deck-search#submit" } do |f| %>
        <%= f.text_field :query, placeholder: "Make me a business terms deck...", class: "form-control",
                         data: { "deck-search-target": "input" } %>
        <div data-deck-search-target="status" class="d-none text-muted small mt-1">
          <span class="spinner-border spinner-border-sm me-1" role="status" aria-hidden="true"></span>
          Creating deck…
        </div>
        <div class="d-flex justify-content-end">
          <%= f.submit "Create", class: "btn btn-OJ-primary fw-bold text-white mt-2",
                                 data: { "deck-search-target": "submit" } %>
        </div>
      <% end %>
    </div>
  </div>
</div>
