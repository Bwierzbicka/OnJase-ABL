<h1>All Flashcards</h1>

<%= link_to "Create a new flashcard", new_flashcard_path, class: "btn btn-primary mb-3" %>

<ul class="list-group">
  <% @flashcards.each do |flashcard| %>
    <li class="list-group-item d-flex justify-content-between align-items-center">

      <div>
        <strong><%= link_to flashcard.question, flashcard_path(flashcard) %></strong>

        <% if flashcard.decks.any? %>
          <div class="mt-1">
            <small>Decks:</small>
            <% flashcard.decks.each do |deck| %>
              <span class="badge bg-secondary"><%= deck.name %></span>
            <% end %>
          </div>
        <% end %>
      </div>

      <div>
        <%= link_to "Edit", edit_flashcard_path(flashcard), class: "btn btn-sm btn-warning" %>
        <%= link_to "Delete",
                    flashcard_path(flashcard),
                    method: :delete,
                    data: { confirm: "Are you sure?" },
                    class: "btn btn-sm btn-danger" %>
      </div>

    </li>
  <% end %>
</ul>
