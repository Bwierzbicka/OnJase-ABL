<% if message.role == "user" %>

  <div class="d-flex justify-content-end mb-2">
     <div class="chat-bubble bg-OJ-primary-light rounded-4 px-3 py-2">
      <%= raw(render_markdown(message.content)) %>
    </div>
  </div>
<% elsif message.role == "assistant" %>
  <div class="d-flex justify-content-start mb-2" id="<%= dom_id(message) %>">
    <div class="chat-bubble bg-white rounded-4 px-3 py-2 border">
      <%= message.content.present? ? raw(render_markdown(message.content)) : "..." %>
    </div>
  </div>
<% end %>
