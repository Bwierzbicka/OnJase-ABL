<%= simple_form_for [chat, message],
    html: { class: "m-0", data: { controller: "message-form", action: "turbo:submit-end->message-form#clear" } } do |f| %>

  <div class="input-group rounded-pill border bg-white overflow-hidden">
    <%= f.input :content, required: true, label: false, wrapper: false,
      input_html: {
        rows: 1,
        class: "form-control border-0 shadow-none bg-transparent ps-3",
        placeholder: "Type a message...",
        autocomplete: "off",
        style: "resize: none; overflow: hidden;",
        data: { "message-form-target": "input", action: "input->message-form#autoGrow" }
        } %>
    <%= button_tag type: "submit", class: "btn btn-OJ-primary rounded-circle m-1 d-flex align-items-center justify-content-center p-0 text-white flex-shrink-0 chat-send-btn" do %>
      <i class="fa-solid fa-arrow-up"></i>
    <% end %>
  </div>
<% end %>
