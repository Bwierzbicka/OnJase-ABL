<div class='m-4'>
  <%= turbo_stream_from current_user, "saved_items" %>
  <h1 class="page-title mb-3">Saved</h1>

  <ul class="nav nav-tabs" id="savedTabs" role="tablist">
    <li class="nav-item" role="presentation">
      <button class="nav-link active" id="words-tab" data-bs-toggle="tab" data-bs-target="#words-pane"
              type="button" role="tab" aria-controls="words-pane" aria-selected="true">
        Words
      </button>
    </li>
    <li class="nav-item" role="presentation">
      <button class="nav-link" id="phrases-tab" data-bs-toggle="tab" data-bs-target="#phrases-pane"
              type="button" role="tab" aria-controls="phrases-pane" aria-selected="false">
        Phrases
      </button>
    </li>
  </ul>

  <div class="tab-content pt-3" id="savedTabsContent">
    <div class="saved-list tab-pane fade show active" id="words-pane" role="tabpanel" aria-labelledby="words-tab">
      <p class="text-muted <%= "d-none" if @saved_words.any? %>" data-add-new-saveable-target="wordsEmpty">No saved words yet.</p>
      <div id="words-list">
        <% @saved_words.reverse.each do |word| %>
          <%= render "word_card", word: word %>
        <% end %>
      </div>
    </div>

    <div class="saved-list tab-pane fade" id="phrases-pane" role="tabpanel" aria-labelledby="phrases-tab">
      <p class="text-muted <%= "d-none" if @saved_phrases.any? %>" data-add-new-saveable-target="phrasesEmpty">No saved phrases yet.</p>
      <div id="phrases-list">
        <% @saved_phrases.reverse.each do |phrase| %>
          <%= render "phrase_card", phrase: phrase %>
        <% end %>
      </div>
    </div>
  </div>

  <%= render "add_new_saveable" %>
</div>
