<div class="m-4">
  <%= link_to :back, class: 'text-decoration-none me-3' do %>
    <i class="fa-solid fa-chevron-left fs-4 text-OJ-text-main"></i>
  <% end %>

  <div class="saved-item-card mt-3">
    <p class="word-french fs-5 mb-2"><%= @phrase.french %></p>
    <hr>
    <p class="word-english fs-5 mb-0"><%= @phrase.english %></p>
  </div>
  <div class='d-flex justify-content-end'>
    <%= link_to "delete", phrase_path(@phrase), class: 'pe-2 text-decoration-none text-danger fw-bold',  data: {turbo_method: :delete, turbo_confirm: "Are you sure?"}%>
  </div>
</div>
