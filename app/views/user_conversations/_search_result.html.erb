<% if results.present? %>

  <div class="">
    <ul class="list-unstyled p-0">
      <% results.each do |result| %>
        <li class="search mb-2">
            <%= form_with url: user_conversations_path, method: :post, scope: :user_conversation, data: { turbo: false } do |f| %>
              <%= f.hidden_field :username, value: result.username %>
            <div class="d-flex justify-content-between">
              <div class="d-flex align-items-center">
                <% if result.avatar.attached? %>
                  <%= cl_image_tag result.avatar.key,
                        width: 36, height: 36, crop: :fill,
                        class: "rounded-circle object-fit-cover",
                        alt: "User avatar" %>
                <% else %>
                  <%= image_tag "avatar_default.png", class: "rounded-circle object-fit-cover", width: 36, height: 36, alt: "Default avatar" %>
                <% end %>
                <%= f.submit result.username, class: "btn btn-link p-0 fw-bold text-decoration-none text-OJ-text-main field ms-2" %>
                <span class="p-0 text-decoration-none text-OJ-text-main field name ms-2"><%= result.display_name %></span>
              </div>
                <div class="current-user me-2">
                  <% if result == current_user %>
                    <p>You</p>
                  <% end %>
                </div>
            </div>
          <% end %>
        </li>
      <% end %>
    </ul>
  </div>
<% end %>
