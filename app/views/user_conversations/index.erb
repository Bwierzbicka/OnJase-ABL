<div class='m-4'>
  <h1 class="page-title">messages</h1>

<div>
  <ul class="list-unstyled p-0">
    <% @user_conversations.each do |conversation| %>
      <% other_user = conversation.other_participant(current_user) %>
      <li class="py-2">
        <% if other_user.avatar.attached? %>
          <%= cl_image_tag other_user.avatar.key,
                crop: :thumb,
                gravity: :face,
                class: "avatar-medium rounded-circle object-fit-cover me-2",
                alt: "User avatar" %>
        <% else %>
          <%= image_tag "avatar_default.png", class: "avatar-medium rounded-circle object-fit-cover me-2", alt: "Default avatar" %>
        <% end %>
        <%= link_to user_conversation_path(conversation), class: "text-decoration-none text-OJ-text-main fw-bold" do %>
          <%= other_user.display_name.present? ? other_user.display_name : other_user.username %>
        <% end %>
      </li>
    <% end %>
  </ul>
  </div>

  <div>
    <%= link_to new_user_conversation_path, class: 'plus-button' do %>
    <i class="fa-regular fa-square-plus"></i>
    <% end %>
  </div>

</div>
<%= render "shared/bottom_navbar" %>
