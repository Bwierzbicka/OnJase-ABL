<%= turbo_stream_from UserConversation %>

<div class='m-4'>

  <%= link_to user_conversations_path, class: 'text-decoration-none' do %>
    <i class="fa-solid fa-chevron-left fs-4 text-OJ-text-main"></i>
  <% end %>

  <h1 class="page-title">new message </h1>

  <div class="mt-5 pt-5" data-controller="partial-user-search" data-partial-user-search-url-value=<%=retrieve_users_user_conversations_path%>> <%# add controller here data-controller %>
    <%= simple_form_for @user_conversation do |f| %>
      <%= f.input :username, label: "Send message to:", placeholder: "Enter username",
              input_html: {
                data: { "partial-user-search-target": "input",
                action: "input->partial-user-search#searchUsername",
                "partial-user-search-url-value": "retrieve_users_user_conversations_path" }
              } %>
      <div class="d-flex justify-content-end">
        <%= f.button :submit, "Search", class: "btn btn-OJ-primary fw-bold text-white" %>
      </div>
    <% end %>
  </div>
  <div id="user_search_results">
    <span>disappear</span>
  </div>
</div>
