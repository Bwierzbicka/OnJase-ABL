<div class='main-container'>
<h1>All Chats</h1>

  <% if @chats.any? %>
    <% @chats.each do |chat| %>
      <ul>
        <li><%= link_to chat.title, chat_path(chat) %></li>
      </ul>
    <% end %>
  <% end %>

  <%= link_to new_chat_path do %>
    <i class="fa-solid fa-circle-plus"></i>
  <% end %>
</div>
<%= render "shared/bottom_navbar" %>
