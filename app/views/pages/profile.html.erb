<div class='text-center mt-5 p-4'>
  <h1>My Proflie</h1>
  <div>
    <% if current_user.avatar.attached? %>
      <%= cl_image_tag current_user.avatar.key,
            gravity: :face,
            class: "avatar-large rounded-circle object-fit-cover d-block",
            alt: "User avatar" %>
    <% else %>
      <%= image_tag "avatar_default.png", class: "avatar-large rounded-circle object-fit-cover d-block", alt: "Default avatar" %>
    <% end %>
  </div>
  <h3> <%= current_user.display_name if current_user.display_name.present? %></h3>
  <p class="my-3">Username: <strong><%= current_user.username %></strong></p>

  <hr>
  <div class='d-flex flex-column gap-3'>
    <%= link_to "Edit profile", edit_user_registration_path, class: 'text-decoration-none text-OJ-text-main' %>

    <%= link_to "LOG OUT", destroy_user_session_path,
                      data: { turbo_method: :delete },
                      class: 'text-decoration-none text-danger' %>
  </div>
</div>
<%= render "shared/bottom_navbar" %>
