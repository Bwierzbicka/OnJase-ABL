<div class='p-4'>
  <div class="m-3 p-4 bg-white rounded-4 shadow-lg text-center">

  <div>
    <% if current_user.avatar.attached? %>
      <%= cl_image_tag current_user.avatar.key,
            gravity: :face,
            class: "avatar-large rounded-circle object-fit-cover d-block shadow-lg",
            alt: "User avatar" %>
    <% else %>
      <%= image_tag "avatar_default.png", class: "avatar-large rounded-circle object-fit-cover d-block shadow-lg", alt: "Default avatar" %>
    <% end %>
  </div>

  <h3> <%= current_user.display_name if current_user.display_name.present? %></h3>
  <p class="my-3">@<strong><%= current_user.username %></strong></p>

  <hr>

    <div class="stats-row d-flex justify-content-between text-center">
      <div class="stat-box mx-2">
        <h3 class="fw-bold mb-1"><%= current_user.user_conversations.count %></h3>
        <small class="text-muted">Conversations</small>
      </div>

      <div class="stat-box mx-2">
        <h3 class="fw-bold mb-1"><%= current_user.saved_items.count %></h3>
        <small class="text-muted">Saved</small>
      </div>

      <div class="stat-box mx-2">
        <h3 class="fw-bold mb-1"><%= current_user.chats.joins(:messages).count %></h3>
        <small class="text-muted">Messages</small>
      </div>
    </div>

    <div class="d-flex flex-column gap-3 mt-5">
      <%= link_to edit_user_registration_path,
            class: "btn btn-OJ-primary text-white py-3  rounded-3" do %>
      Edit Profile
      <% end %>

      <%= link_to destroy_user_session_path,
            data: { turbo_method: :delete },
            class: "btn btn-outline-danger py-3  rounded-3" do %>
        Log Out
      <% end %>
    </div>
</div>

</div>
