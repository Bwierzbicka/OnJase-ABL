<div id='profile-container'>
  <h1>My Proflie</h1>
  <div>
    <% if current_user.avatar.attached? %>
      <%= cl_image_tag current_user.avatar.key,
            crop: :thumb,
            gravity: :face,
            class: "avatar-large",
            alt: "User avatar" %>
    <% else %>
      <%= image_tag "OnJase_logo.png", class: "avatar-large", alt: "Default avatar" %>
    <% end %>
  </div>
  <strong>username</strong>
  <hr>
  <p>link to edit profile</p>
  <p>link to delete</p>
  <%= link_to "LOG OUT", destroy_user_session_path,
                    data: { turbo_method: :delete } %>
</div>
<%= render "shared/bottom_navbar" %>
