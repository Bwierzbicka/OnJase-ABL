<div id="profile-container" class='main-container'>
  <h1>My Proflie</h1>
  <div>
    <% if current_user.avatar.attached? %>
      <%= cl_image_tag current_user.avatar.key,
            gravity: :face,
            class: "avatar-large",
            alt: "User avatar" %>
    <% else %>
      <%= image_tag "OnJase_logo.png", class: "avatar-large", alt: "Default avatar" %>
    <% end %>
  </div>
  <strong>
    <%= current_user.display_name.present?  ?  current_user.display_name : current_user.username %>
  </strong>
  <hr>
  <%= link_to "edit profile", edit_user_registration_path %><br>


  <%= link_to "LOG OUT", destroy_user_session_path,
                    data: { turbo_method: :delete } %>
</div>
<%= render "shared/bottom_navbar" %>
