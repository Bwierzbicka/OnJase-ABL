<%= simple_form_for ([user_conversation, user_conversation_message]),
    html: { data: { controller: "message-form", action: "turbo:submit-end->message-form#clear" } } do |f| %>


  <%= f.input :content, required: true, label: false,
      input_html: { data: { "message-form-target": "input" } } %>

  <%= f.button :submit, "Send", class: "btn btn-primary float-end" %>
<% end %>
