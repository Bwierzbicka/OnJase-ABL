<%= simple_form_for ([user_conversation, user_conversation_message]),
    html: { class: "m-0 d-flex", data: { controller: "message-form", action: "turbo:submit-end->message-form#clear" } } do |f| %>

  <div class="input-group rounded-5 border bg-white overflow-hidden">
    <%= f.input :content, required: true, label: false, wrapper: false,
        input_html: {
          class: "form-control border-0 shadow-none bg-transparent ps-3",
          placeholder: "Type a message...",
          autocomplete: "off",
          data: {
            "message-form-target": "input",
            "typing-assistant-target": "input",
            action: "input->typing-assistant#inputChanged"
          }
        } %>
    <button type="submit" class="btn btn-OJ-primary rounded-circle m-1 d-flex align-items-center justify-content-center
                                 p-0 text-white flex-shrink-0 chat-send-btn">
      <i class="fa-solid fa-arrow-up"></i>
    </button>
  </div>

<% end %>
